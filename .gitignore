# =========================================================================
# 1. ZALEŻNOŚCI I MENEDŻERY PAKIETÓW (node_modules, yarn, pnpm)
# =========================================================================
node_modules/
/node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================================================
# 2. PLIKI ŚRODOWISKOWE Z SEKRETAMI (KLUCZOWE DLA BEZPIECZEŃSTWA!)
# =========================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*
*.env
# WYJĄTEK: Gwarantujemy, że bezpieczny szablon .env.example ZOSTANIE wysłany:
!.env.example

# =========================================================================
